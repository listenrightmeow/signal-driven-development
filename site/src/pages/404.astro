---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page Not Found | Signal-Driven Development"
  description="The page you're looking for doesn't exist."
  noindex={true}
>
  <section class="hero" style="min-height: 60vh; justify-content: center;">
    <h1>Page not found</h1>
    <p class="hero__subline">This gap isn't in the report.</p>
    <div class="hero__actions">
      <a href="/" class="btn btn--primary">Back to the methodology →</a>
      <a href="/walkthrough" class="btn btn--secondary">Try the walkthrough</a>
    </div>
  </section>
</Base>
